# ========================================
# SERVER CONFIGURATION
# ========================================
# Client URL for CORS and Socket.IO
CLIENT_URL=http://localhost:4080

# ========================================
# MODEL SERVICE URLS
# ========================================
# GeoCLIP location prediction service
GEOCLIP_URL=http://geoclip:8000

# Vision/Commentary generation service
VISION_URL=http://vision:8001

# ========================================
# GAME SETTINGS
# ========================================
# Round duration in seconds (0 = unlimited for progressive/duel mode)
ROUND_DURATION_SEC=30

# ========================================
# SERVER LIMITS & ACCESS CONTROL
# ========================================
# Maximum number of simultaneous lobbies
MAX_LOBBIES=5

# Default player/photo limits (can be overridden per-token in data/tokens.json)
DEFAULT_MAX_PLAYERS=20
DEFAULT_MAX_PHOTOS_PER_PLAYER=10

# Feature flags (set to 'false' to restrict by default; tokens can override)
DEFAULT_ALLOW_ALL_MAPS=true
DEFAULT_ALLOW_AI_GUESSING=true
DEFAULT_ALLOW_AUTO_NAMING=true
DEFAULT_ALLOW_VISION_COMMENTARY=true

# ========================================
# FILE UPLOAD SETTINGS
# ========================================
# Maximum file size for photo uploads in MB.
# Note: client/nginx.conf has client_max_body_size 50M — raising this above 50
# will fail at the nginx layer before reaching the server.
UPLOAD_LIMIT_MB=20

# Maximum number of photos each player can upload
MAX_PHOTOS_PER_PLAYER=10

# Data directory for persistent storage
DATA_DIR=./data

# Game statistics file path
GAME_STATS_FILE=./data/game-stats.json

# ========================================
# MODEL SERVICE CONFIGURATION
# ========================================
# Number of threads for vision model
THREADS=4
THREADS_BATCH=4

# Number of threads for GeoCLIP model
NUM_THREADS=4

# Server-side AI concurrency limits
GEO_CONCURRENCY=2
VISION_CONCURRENCY=1

# Delay between sequential vision model requests (ms)
VISION_INTER_PHOTO_DELAY_MS=500

# ========================================
# MAP SETTINGS (Used by client via Vite)
# ========================================
# Default map bounding box: [south, west, north, east]
VITE_MAP_BBOX_SOUTH=35
VITE_MAP_BBOX_WEST=-10
VITE_MAP_BBOX_NORTH=70
VITE_MAP_BBOX_EAST=40
